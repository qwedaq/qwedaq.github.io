---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found | Aveen Dayal" description="The requested page could not be found.">
  <section class="not-found section-shell">
    <p class="eyebrow">404</p>
    <h1>This page is outside the current research map.</h1>
    <p>The link may have changed, or the page may not exist.</p>
    <a class="button button-primary" href="/">Return home</a>
  </section>
</BaseLayout>
